{
  "projectName": "QuiztalWorld",
  "version": "1.0.0",
  "lastUpdated": "2025-08-26",
  "maintainers": ["AI Development Team"],
  
  "mobileFriendlyGuide": {
    "overview": {
      "description": "Comprehensive guide for maintaining mobile-friendly code in QuiztalWorld game",
      "purpose": "Ensure consistent mobile experience and prevent common mobile development issues",
      "scope": "All game scenes, UI components, and asset management"
    },
    
    "coreRequirements": {
      "responsiveDesign": {
        "mobileBreakpoint": "768px",
        "detectionMethod": "this.scale.width < 768 || device detection",
        "minimumDimensions": {
          "width": "320px",
          "height": "568px"
        },
        "mandatoryImplementations": [
          "isMobile detection in all scenes",
          "Responsive UI scaling",
          "Touch-friendly button sizes (minimum 44px)",
          "Proper viewport meta tags"
        ]
      },
      
      "touchControls": {
        "virtualJoystick": {
          "location": "src/managers/MobileControlsManager.ts",
          "assets": ["joystick-base.png", "joystick.png"],
          "position": "Bottom-left (20% from edge)",
          "configuration": {
            "joystickScale": 1.2,
            "buttonScale": 1.3,
            "joystickAlpha": 0.7,
            "buttonAlpha": 0.8,
            "velocitySmoothing": 0.15,
            "directionChangeDelay": 150,
            "directionChangeThreshold": 0.3,
            "stopThreshold": 0.5
          },
          "tuning": {
            "utility": "src/utils/MovementTuningHelper.ts",
            "parameters": {
              "velocitySmoothing": {
                "description": "Controls how smoothly velocity changes (0.01-1.0, lower = smoother)",
                "default": 0.15,
                "range": [0.01, 1.0]
              },
              "directionChangeDelay": {
                "description": "Delay in ms before allowing direction change to prevent flickering",
                "default": 150,
                "range": [50, 500]
              },
              "directionChangeThreshold": {
                "description": "Minimum joystick movement to trigger direction change",
                "default": 0.3,
                "range": [0.1, 1.0]
              },
              "stopThreshold": {
                "description": "Speed threshold below which character stops immediately",
                "default": 0.5,
                "range": [0.1, 2.0]
              }
            }
          }
        },
        "interactButton": {
          "asset": "button-interact.png",
          "position": "Bottom-right (15% from edge)",
          "functionality": "Simulates 'C' key press for NPC interaction"
        },
        "touchTargets": {
          "minimumSize": "44px",
          "padding": "15px for mobile, 10px for desktop",
          "hitArea": "Should extend beyond visual bounds"
        }
      },
      
      "performance": {
        "frameRate": {
          "mobile": "30 FPS",
          "desktop": "60 FPS"
        },
        "rendering": {
          "batchSize": {
            "mobile": 2000,
            "desktop": 4096
          },
          "maxTextures": {
            "mobile": 8,
            "desktop": 16
          },
          "powerPreference": {
            "mobile": "low-power",
            "desktop": "high-performance"
          }
        },
        "assetOptimization": {
          "inlineLimit": "4096 bytes",
          "imageFormats": ["PNG for UI", "WebP for modern browsers"],
          "audioFormats": ["MP3", "OGG for fallback"]
        }
      }
    },
    
    "sceneImplementations": {
      "requiredInAllScenes": {
        "mobileDetection": "const isMobile = this.scale.width < 768;",
        "responsiveLayout": "Adjust positions, sizes, and spacing based on isMobile",
        "eventHandlers": "Different input handling for touch vs keyboard/mouse",
        "resizeHandling": "this.scale.on('resize', this.updateLayout, this);"
      },
      
      "sceneSpecific": {
        "UIScene": {
          "mobileFeatures": [
            "Smaller button sizes with larger touch areas",
            "Repositioned elements for thumb accessibility", 
            "Mobile-specific instructions text",
            "Hidden tooltips on mobile",
            "Dynamic button repositioning on resize",
            "Safe margin calculations to prevent cut-off",
            "Increased header height (70px) for better touch targets"
          ],
          "layout": {
            "buttonSpacing": "45px mobile, 80px desktop",
            "headerHeight": "70px mobile, 50px desktop",
            "buttonSize": "35px mobile, 40px desktop",
            "touchPadding": "8px mobile, 10px desktop",
            "rightMargin": "20px safe margin from screen edge",
            "fontSize": "16px mobile icons, 18px desktop icons"
          },
          "positioning": {
            "calculation": "Math.max(screen.width - totalWidth - margin, minPosition)",
            "safeArea": "Ensures buttons never extend beyond screen bounds",
            "centerOrigin": "Uses center origin for better positioning control",
            "dynamicResize": "Repositions buttons on screen orientation change"
          }
        },
        
        "InventoryScene": {
          "mobileAdaptations": [
            "Window size: 95% width, 90% height on mobile",
            "Larger close button (20px radius vs 15px)",
            "Reduced items per page (5 vs 15)",
            "No keyboard shortcuts on mobile"
          ]
        },
        
        "CharacterSelectionScene": {
          "touchControls": [
            "Arrow buttons for character navigation",
            "Larger confirm button",
            "Touch-friendly positioning"
          ]
        },
        
        "TokenClaimScene": {
          "mobileRestrictions": [
            "Disabled on mobile devices",
            "Show desktop-only message",
            "Redirect to desktop instructions"
          ]
        },
        
        "WalletVerificationScene": {
          "mobileHandling": [
            "Show mobile incompatibility message",
            "Provide desktop alternative instructions"
          ]
        }
      }
    },
    
    "assetManagement": {
      "mobileAssets": {
        "directory": "public/assets/ui/",
        "requiredFiles": [
          "joystick-base.png",
          "joystick.png", 
          "button-interact.png",
          "arrow-left.png",
          "arrow-right.png",
          "button-confirm.png"
        ],
        "loadingLocation": "src/scenes/BootScene.ts",
        "optimization": "Assets should be optimized for mobile bandwidth"
      },
      
      "loadingStrategy": {
        "critical": "Load mobile assets first",
        "progressive": "Load additional assets after core game loads",
        "fallbacks": "Provide fallback assets for different screen densities"
      }
    },
    
    "commonPatterns": {
      "mobileDetection": {
        "standardImplementation": "const isMobile = this.scale.width < 768;",
        "extendedDetection": "this.game.device.os.android || this.game.device.os.iOS || this.game.device.input.touch",
        "usageLocations": "All scene create() methods"
      },
      
      "responsiveText": {
        "pattern": "fontSize: isMobile ? 'Xpx' : 'Ypx'",
        "example": "fontSize: isMobile ? '12px' : '14px'",
        "padding": "padding: { x: isMobile ? 5 : 10, y: 5 }"
      },
      
      "responsivePositioning": {
        "pattern": "position based on screen percentage",
        "example": "x: this.scale.width * 0.2",
        "considerations": "Maintain thumb-accessible zones"
      },
      
      "touchInteraction": {
        "interactiveArea": ".setInteractive({ useHandCursor: true })",
        "touchFeedback": "Visual feedback on pointerdown/pointerup",
        "accessibility": "Larger touch targets with padding"
      }
    },
    
    "testingGuidelines": {
      "devices": {
        "minimum": "iPhone 5s (320x568)",
        "optimal": "iPhone 12 Pro (390x844), Samsung Galaxy S21 (360x800)",
        "tablet": "iPad (768x1024)"
      },
      
      "testCases": [
        {
          "category": "Layout",
          "tests": [
            "All UI elements visible on smallest screen",
            "No overlapping elements",
            "Touch targets adequately sized",
            "Text remains readable"
          ]
        },
        {
          "category": "Controls", 
          "tests": [
            "Virtual joystick responds correctly",
