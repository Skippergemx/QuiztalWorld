        {
          "category": "Compatibility",
          "tests": [
            "Works on iOS Safari",
            "Works on Android Chrome",
            "PWA installation possible",
            "No console errors on mobile"
          ]
        }
      ]
    },
    
    "commonIssues": {
      "preventionStrategies": [
        {
          "issue": "Elements too small to touch",
          "prevention": "Always use minimum 44px touch targets",
          "solution": "Add padding to interactive elements"
        },
        {
