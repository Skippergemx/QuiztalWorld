rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow players to read/write their own data
    match /players/{playerId} {
      allow read, write: if request.auth != null && request.auth.uid == playerId;
      
      // Allow players to read/write their own reward history
      match /rewardHistory/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == playerId;
      }

      // Allow players to read/write their own nfts
      match /nfts/{nftId} {
        allow read, write: if request.auth != null && request.auth.uid == playerId;
      }
      
      // Allow players to read/write their own inventory items
      match /inventory/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == playerId;
      }
    }
    
    // Allow users to read/write their own user data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public collection, accessible by everyone
    match /public/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny for all other cases
    match /{document=**} {
      allow read, write: if false;
    }
  }
}